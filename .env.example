# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Comma-separated Discord user IDs allowed to use the bot
ALLOWED_USER_IDS=123456789,987654321

# Absolute path to the folder containing your repos
# Channel name maps to BASE_FOLDER/<channel-name>
# Worktree syntax: channel named  my-repo🌲feat  maps to  BASE_FOLDER/my-repo/worktrees/feat
BASE_FOLDER=/Users/you/repos

# Port for the MCP permission server (used in cc plan/approve modes).
# If unset, it is derived from BOT_ROLE (worker→3001, manager→3011) so a second
# instance doesn't collide on the worker's port.
MCP_SERVER_PORT=3001

# ── Multiple instances (worker + manager) ──────────────────────────────────
# This instance's role. Run two processes — each with its own DISCORD_TOKEN — to
# have a worker and a manager listen in the same channels. The role auto-derives
# this instance's DB file (worker→sessions.db, manager→manager-sessions.db) so the
# two never share state. Leave unset for the historical single-bot behavior.
# BOT_ROLE=manager

# Which role replies to messages that don't @-mention a specific bot. Set the
# SAME value in both instances' env. Defaults to "worker". The non-default
# instance only responds when it is explicitly @-mentioned; when one bot is
# addressed, the other ignores the message.
# DEFAULT_RESPONDER=worker

# Optional explicit DB path. If set it wins over the role-derived default above.
# DB_PATH=

# MCP approval settings
MCP_APPROVAL_TIMEOUT=30
MCP_DEFAULT_ON_TIMEOUT=deny

# GitHub webhook HMAC secret — must match AGENT_WEBHOOK_SECRET in each repo's
# GitHub Actions secrets (carbon, discord-ai-terminal, etc.)
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=

# Port for the GitHub webhook listener
GITHUB_WEBHOOK_PORT=3002

# Public URL where GitHub can reach the webhook server (must be reachable from the internet)
# Use a stable tunnel or domain — e.g. a Cloudflare named tunnel pointing to localhost:3002
GITHUB_WEBHOOK_URL=https://webhook.example.com

# Comma-separated list of repos to auto-register the webhook on startup (e.g. owner/repo)
GITHUB_WEBHOOK_REPOS=owner/repo

# Shared secret for the /preview-ready webhook endpoint (optional but recommended)
# Generate with: openssl rand -hex 32
# Must match PREVIEW_READY_SECRET in the carbon GitHub repo secrets
PREVIEW_READY_SECRET=

# Optional: Discord channel ID where each thread becomes its own discord-ai-terminal
# bot instance (worker). Each thread gets a git worktree of the bot repo and runs
# src/index.ts from it in worker mode, sending output via REST instead of a
# WebSocket gateway. Session state persists per-thread via the worktree's sessions.db.
DISCORD_AI_TERMINAL=
