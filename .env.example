# Discord bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Comma-separated Discord user IDs allowed to use the bot
ALLOWED_USER_IDS=123456789,987654321

# Absolute path to the folder containing your repos
# Channel name maps to BASE_FOLDER/<channel-name>
# Worktree syntax: channel named  my-repo🌲feat  maps to  BASE_FOLDER/my-repo/worktrees/feat
BASE_FOLDER=/Users/you/repos

# Port for the MCP permission server (used in cc plan/approve modes)
MCP_SERVER_PORT=3001

# MCP approval settings
MCP_APPROVAL_TIMEOUT=30
MCP_DEFAULT_ON_TIMEOUT=deny

# Shared secret for the /preview-ready webhook endpoint (optional but recommended)
# Generate with: openssl rand -hex 32
# Must match PREVIEW_READY_SECRET in the carbon GitHub repo secrets
PREVIEW_READY_SECRET=
